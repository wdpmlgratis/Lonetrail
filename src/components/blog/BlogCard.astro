---
import StripeFooter from "../ui/StripeFooter.astro";
import Tag from "../ui/Tag.astro";

interface Props {
	title: string;
	summary: string;
	category: "Tech" | "Log" | "Meta";
	date: string;
	index: number;
	href: string;
}

const { title, summary, category, date, index, href } = Astro.props;

const getTagVariant = (cat: string) => {
	switch (cat) {
		case "Tech":
			return "dark";
		case "Log":
		case "Meta":
			return "outline";
		default:
			return "default";
	}
};

const formattedIndex = index.toString().padStart(2, "0");
---

<a
    href={href}
    class="group relative w-full max-w-[840px] bg-lt-bg paper-texture shadow-2xl px-8 sm:px-16 py-10 overflow-hidden block hover:bg-lt-surface transition-colors duration-150"
>
    <div class="relative z-10">
        <div class="flex justify-between items-center mb-6">
            <div class="flex items-center gap-2">
                <Tag variant={getTagVariant(category)}>{category}</Tag>
            </div>
            <span class="font-mono text-[11px] text-lt-ghost uppercase tracking-widest">
                {`RPT_${formattedIndex}`} · {date}
            </span>
        </div>

        <div class="flex justify-between items-start gap-8">
            <div class="flex-1 min-w-0">
                <h2 class="font-display text-[24px] sm:text-[28px] leading-[1.1] tracking-tight text-lt-ink uppercase mb-4 group-hover:text-lt-accent transition-colors font-black">
                    {title}
                </h2>
                <p class="font-cn text-[14px] text-lt-muted leading-[1.75] line-clamp-2 text-justify">
                    {summary}
                </p>
            </div>
            <span class="font-display text-3xl text-lt-ghost group-hover:text-lt-accent transition-colors flex-shrink-0 mt-1 font-black">
                →
            </span>
        </div>
    </div>
    <StripeFooter />
</a>
