---
import { Icon } from "astro-icon/components";
import { getPostUrlBySlug } from "../../utils/url-utils";

interface Props {
	slug?: string;
	title?: string;
	index: number;
}
const { slug, title, index } = Astro.props;
---
{slug ? (
    <a
        href={getPostUrlBySlug(slug)}
        class={`group relative p-6 flex flex-col justify-between transition-all hover:bg-[var(--primary)]/[0.03] dark:hover:bg-[var(--primary)]/[0.1] min-h-[160px] bg-[var(--card-bg)]`}
    >
        <div class="flex items-center justify-between mb-4">
            <span class="text-[9px] font-black text-30 tracking-[0.2em] italic uppercase opacity-50">0{index + 1}</span>
            <div class="w-8 h-8 rounded-full bg-[var(--primary)]/5 flex items-center justify-center group-hover:bg-[var(--primary)] group-hover:text-white text-[var(--primary)] transition-all">
                 <Icon name="material-symbols:explore-outline-rounded" class="text-base transition-all group-hover:scale-110" />
            </div>
        </div>
        <h4 class="text-sm font-bold text-75 group-hover:text-[var(--primary)] transition-colors line-clamp-3 leading-relaxed mb-4 flex-1">
            {title}
        </h4>
        <div class="flex items-center gap-1.5 text-[9px] font-black uppercase text-[var(--primary)] opacity-0 group-hover:opacity-100 transition-all translate-y-2 group-hover:translate-y-0">
            <span>Read</span>
            <Icon name="material-symbols:arrow-right-alt-rounded" class="text-sm" />
        </div>
    </a>
) : (
    <div class={`p-6 flex flex-col items-center justify-center opacity-10 italic bg-[var(--card-bg)] min-h-[160px]`}>
        <span class="text-[9px] font-black tracking-widest italic uppercase">Empty Slot</span>
    </div>
)}
