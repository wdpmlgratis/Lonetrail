---
import { profileConfig } from "@/config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { formatFullDate } from "../../utils/date-utils";

interface Props {
	published: Date;
}
const { published } = Astro.props;
---
<div class="flex flex-wrap items-center gap-x-2 text-[10px] font-bold uppercase tracking-[0.15em] text-black/40 dark:text-white/30">
    <div class="flex items-center gap-1.5">
        <span>{i18n(I18nKey.author)}:</span>
        <img src={profileConfig.avatar} alt={profileConfig.name} class="w-5 h-5 object-cover rounded" />
        <span class="text-[var(--primary)]">{profileConfig.name}</span>
    </div>
    <span class="opacity-20 text-[8px]">•</span>
    <div class="flex items-center gap-1.5">
        <span>{i18n(I18nKey.publishedAt)}:</span>
        <span class="text-black/60 dark:text-white/60 font-mono italic">{formatFullDate(published).split(' ')[0]}</span>
    </div>
    <span class="opacity-20 text-[8px]">•</span>
    <div class="flex items-center gap-1.5">
        <span>{i18n(I18nKey.license)}:</span>
        <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" class="text-[var(--primary)] hover:underline decoration-dashed underline-offset-4 transition-all">CC BY-NC-SA 4.0</a>
    </div>
</div>
