---
interface Props {
	nodes: Array<{ title: string; href: string }>;
	nextPost?: { title: string; href: string; id: string };
}

const { nodes = [], nextPost } = Astro.props;
---
<div class="relative w-full max-w-[840px] bg-lt-ink paper-texture shadow-2xl px-6 md:px-16 py-10 md:py-12 overflow-hidden">
    <div class="absolute -top-10 -right-20 pointer-events-none select-none z-0">
        <span class="font-display text-[150px] md:text-[240px] text-lt-bg opacity-[0.02] leading-none uppercase whitespace-nowrap">
            Nodes
        </span>
    </div>

    <div class="relative z-10 flex justify-between items-start mb-10 md:mb-12">
        <div class="space-y-1">
            <div class="flex items-center gap-2">
                <div class="w-[3px] h-[10px] bg-lt-accent"></div>
                <span class="text-[11px] font-mono tracking-[0.2em] font-semibold text-lt-bg uppercase">
                    Chapter_07 // Related_Archives
                </span>
            </div>
            <div class="text-[11px] font-mono text-lt-bg/30 uppercase tracking-widest leading-none">
                Registry: PTL-SCAN-DATABASE
            </div>
        </div>
    </div>

    <div class="relative z-10 grid grid-cols-1 md:grid-cols-3 gap-0 border border-white/10 mb-12">
        {nodes.map((node, i) => (
            <a
                href={node.href}
                class="group px-6 pt-6 pb-10 md:pb-12 border-b md:border-b-0 md:border-r border-white/10 last:border-r-0 hover:bg-white/5 transition-all flex flex-col justify-between"
            >
                <div class="flex justify-between items-start mb-4 md:mb-8">
                    <span class="text-[10px] font-mono text-lt-bg/40 font-bold tracking-tighter">
                        NODE_0{(i + 1).toString().padStart(2, "0")}
                    </span>
                    <span class="text-[10px] text-lt-accent opacity-0 group-hover:opacity-100 transition-opacity">
                        ● ACTIVE
                    </span>
                </div>
                <h4 class="font-cn text-[15px] text-lt-bg/90 font-bold leading-[1.6] mb-6 group-hover:text-white transition-colors line-clamp-2">
                    {node.title}
                </h4>
                <span class="font-mono text-[10px] text-lt-bg/30 uppercase tracking-widest">
                    Read_Node &gt;&gt;
                </span>
            </a>
        ))}
    </div>

    {nextPost && (
        <a
            href={nextPost.href}
            class="relative z-10 group flex items-center justify-between p-5 md:p-6 border border-lt-accent/50 bg-lt-accent/5 hover:bg-lt-accent transition-all duration-200"
        >
            <div class="flex items-center gap-4 md:gap-6 min-w-0">
                <span class="font-display text-2xl md:text-3xl text-lt-accent group-hover:text-white shrink-0">
                    →
                </span>
                <div class="space-y-1 min-w-0">
                    <span class="block text-[9px] font-mono text-lt-accent group-hover:text-white/80 uppercase tracking-widest leading-none">
                        Access_Next_Log
                    </span>
                    <h5 class="font-cn text-[15px] md:text-[16px] text-lt-bg font-bold truncate">
                        {nextPost.title}
                    </h5>
                </div>
            </div>
            <span class="hidden md:block font-mono text-[10px] text-lt-accent group-hover:text-white uppercase font-bold shrink-0">
                {nextPost.id}
            </span>
        </a>
    )}

</div>
