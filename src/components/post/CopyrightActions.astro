---
import { Icon } from "astro-icon/components";
import Button from "../ui/Button";

interface Props {
	url: string;
	shareText: string;
}
const { url, shareText } = Astro.props;
---
<Button
    id="share-btn"
    dataShare={shareText}
    variant="unstyled"
    class="w-full mt-4 px-3 py-3 rounded-[var(--radius-small)] bg-primary/5 hover:bg-primary/10 border border-primary/20 flex items-center justify-center gap-2 transition-all group/share active:scale-[0.98] cursor-pointer"
>
    <Icon name="material-symbols:share" class="text-base text-primary" />
    <span class="text-[10px] font-black text-primary uppercase tracking-[0.2em]">Copy Post Info (Copy All)</span>
</Button>
<script>
    function initShareBtn() {
        const shareBtn = document.getElementById('share-btn');
        const toast = document.getElementById('copy-toast');

        if (shareBtn && toast) {
            shareBtn.addEventListener('click', () => {
                const content = shareBtn.getAttribute('data-share') || '';
                navigator.clipboard.writeText(content).then(() => {
                    toast.classList.add('show');
                    setTimeout(() => toast.classList.remove('show'), 2000);
                });
            });
        }
    }

    initShareBtn();
    document.addEventListener('astro:page-load', initShareBtn);
    document.addEventListener('astro:after-swap', initShareBtn);
</script>
