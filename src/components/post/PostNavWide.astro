---
import { Icon } from "astro-icon/components";
import { getPostUrlBySlug } from "../../utils/url-utils";

interface Props {
	slug?: string;
	title?: string;
	type: "PREVIOUS" | "NEXT";
}
const { slug, title, type } = Astro.props;
const isPrev = type === "PREVIOUS";
---
{slug ? (
    <a
        href={getPostUrlBySlug(slug)}
        class={`group flex items-center justify-between px-6 py-5 transition-all hover:bg-[var(--primary)]/[0.05] dark:hover:bg-[var(--primary)]/[0.15] bg-[var(--card-bg)] hover:shadow-inner`}
    >
        <div class="flex items-center gap-5 overflow-hidden w-full">
            <div class={`w-10 h-10 shrink-0 rounded-[var(--radius-small)] bg-[var(--primary)]/10 flex items-center justify-center text-[var(--primary)] group-hover:bg-[var(--primary)] group-hover:text-white transition-all`}>
                <Icon name={isPrev ? "material-symbols:arrow-back-rounded" : "material-symbols:arrow-forward-rounded"} class="text-2xl" />
            </div>
            <div class="flex flex-col min-w-0 pr-4">
                <span class="text-[10px] font-black text-30 tracking-[0.2em] uppercase mb-1">{type}</span>
                <span class="text-base font-bold text-75 leading-snug group-hover:text-[var(--primary)] transition-colors line-clamp-2">
                    {title}
                </span>
            </div>
        </div>
        <div class="shrink-0 flex items-center justify-center opacity-30 group-hover:opacity-100 transition-all translate-x-2 group-hover:translate-x-0">
             <Icon name="material-symbols:chevron-right-rounded" class="text-2xl text-[var(--primary)]" />
        </div>
    </a>
) : (
    <div class={`px-6 py-5 flex items-center justify-center opacity-20 text-[10px] font-black tracking-widest italic uppercase bg-[var(--card-bg)]`}>
        No {type} Post
    </div>
)}
