---
import Footer from "@components/layout/Footer.astro";
import type { MarkdownHeading } from "astro";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	category?: string;
	entities?: any[];
	citations?: string[];
	published?: Date;
	updated?: Date;
	tags?: string[];
	wordCount?: number;
	hideBanner?: boolean;
}
const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	category,
	entities,
	citations,
	published,
	updated,
	tags,
	wordCount,
} = Astro.props;
---
<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle} category={category} entities={entities} citations={citations} published={published} updated={updated} tags={tags} wordCount={wordCount}>
    <slot slot="head" name="head"></slot>
    <header id="page-header" class="fixed top-0 left-0 right-0 z-[100] h-[4.5rem] bg-lt-surface/80 backdrop-blur-xl border-b border-lt-border/20 shadow-sm flex items-center transition-all duration-300">
        <div class="w-full max-w-[var(--page-width)] mx-auto px-4">
        </div>
    </header>
    <div class="flex flex-col min-h-screen pt-[4.5rem]">
        <div class="relative z-30 w-full max-w-[var(--page-width)] mx-auto px-4 md:px-6 pb-12 mt-8">
            <main class="min-w-0">
                <div class="flex flex-col gap-4">
                    <slot />
                </div>
            </main>
        </div>
        <footer class="mt-auto w-full max-w-[var(--page-width)] mx-auto px-4 py-12">
            <Footer />
        </footer>
    </div>
    <script>
        function updateHeader() {
            const header = document.getElementById('page-header');
            if (window.scrollY > 10) {
                header?.classList.add('shadow-xl', 'shadow-black/5');
            } else {
                header?.classList.remove('shadow-xl', 'shadow-black/5');
            }
        }
        window.addEventListener('scroll', updateHeader);
        document.addEventListener('astro:page-load', updateHeader);
    </script>
</Layout>
