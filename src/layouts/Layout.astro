---
import PostHog from "../components/posthog.astro";
import { getMetaDescription, getPageTitle } from "../seo/meta";
import { generateJsonLd } from "../seo/schema";
import "../styles/tokens.css";
import "../styles/markdown.css";
import "../styles/transition.css";
import "../styles/expressive-code.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import ConfigCarrier from "@components/layout/ConfigCarrier.astro";
import { SideDrawer } from "@components/layout/SideDrawer";
import Footer from "@components/layout/Footer.astro";
import { navBarConfig, profileConfig, siteConfig } from "@/config";
import { i18n } from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	DEFAULT_BANNER_ASPECT_RATIO,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
	PAGE_WIDTH,
} from "../constants/constants";
import { defaultFavicons } from "../constants/icon";
import { LinkPresets } from "../constants/link-presets";
import { type Favicon, LinkPreset, type NavBarLink } from "../types/config";
import { isHomePath, makeUrl } from "../utils/url-utils";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	category?: string;
	entities?: any[];
	citations?: string[];
	published?: Date;
	updated?: Date;
	tags?: string[];
	wordCount?: number;
	bannerAspectRatio?: number;
}
let {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	category,
	entities,
	citations,
	published,
	updated,
	tags,
	wordCount,
	bannerAspectRatio,
} = Astro.props;
let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);
const isHomePage = isHomePath(Astro.url.pathname);
const enableBanner = siteConfig.banner.enable;
const pageTitle = getPageTitle(title);
const metaDescription = getMetaDescription(description);
const siteLang = (lang || siteConfig.lang).replace("_", "-");
const trailingSlashNormalizer = /\/?$/;
const postsBasePath = makeUrl("/posts/").replace(trailingSlashNormalizer, "/");
const currentPath = Astro.url.pathname.replace(trailingSlashNormalizer, "/");
const isPostPage = currentPath.startsWith(postsBasePath);
let canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
if (!canonicalURL.endsWith("/")) {
	const lastPart = canonicalURL.split("/").pop();
	if (lastPart && !lastPart.includes(".")) {
		canonicalURL += "/";
	}
}
const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;
let ogImage = new URL(banner || "(cfg as any).site.og_image", Astro.site).toString();
const ogType = setOGTypeArticle ? "article" : "website";
const siteName = siteConfig.title;
const jsonLd = generateJsonLd({
	siteUrl: Astro.site?.toString() || "https://your-site.com/",
	canonicalURL,
	title,
	metaDescription,
	siteLang,
	isHomePage,
	isPostPage,
	published,
	updated,
	ogImage,
	tags,
	category,
	wordCount,
	entities,
	citations,
	currentPath,
});
// ... (rest of the file remains)
const breadcrumbItems: any[] = [
	{
		"@type": "ListItem",
		position: 1,
		name: "Home",
		item: Astro.site,
	},
];
if (isPostPage) {
	if (category) {
		breadcrumbItems.push({
			"@type": "ListItem",
			position: 2,
			name: category,
			item: new URL(`/categories/${category}/`, Astro.site).toString(),
		});
		breadcrumbItems.push({
			"@type": "ListItem",
			position: 3,
			name: title || "Post",
			item: canonicalURL,
		});
	} else {
		breadcrumbItems.push({
			"@type": "ListItem",
			position: 2,
			name: title || "Post",
			item: canonicalURL,
		});
	}
} else if (!isHomePage) {
	breadcrumbItems.push({
		"@type": "ListItem",
		position: 2,
		name: title || "Page",
		item: canonicalURL,
	});
}
jsonLd["@graph"].push({
	"@type": "BreadcrumbList",
	"@id": `${canonicalURL}#breadcrumb`,
	itemListElement: breadcrumbItems,
});
---
<!DOCTYPE html>
<html lang={siteLang} class="bg-[var(--page-bg)] text-[14px] md:text-[15px] 2xl:text-[16px]">
	<head>
		<script is:inline>
			(function() {
				// Force light mode
				document.documentElement.classList.remove('dark');
				localStorage.setItem('theme', 'light');
			})();
		</script>
		<title>{pageTitle}</title>
		<Font cssVariable="--font-mono-var" />
		<Font cssVariable="--font-serif" />
		<Font cssVariable="--font-sans-pj" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="referrer" content="no-referrer-when-downgrade" />
		<meta name="description" content={metaDescription} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#39C5BB" />
		<meta name="author" content={profileConfig.name} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" hreflang={siteLang} href={canonicalURL} />
		<link rel="alternate" hreflang="x-default" href={canonicalURL} />
		<link rel="webmention" href="" />
		<link rel="pingback" href="" />
		<link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} - RSS`} href="/rss.xml" />
		<link rel="alternate" type="application/atom+xml" title={`${siteConfig.title} - Atom`} href="/atom.xml" />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content={siteName} />
		{isPostPage && published && <meta property="article:published_time" content={published.toISOString()} />}
		{isPostPage && updated && <meta property="article:modified_time" content={updated.toISOString()} />}
		{isPostPage && category && <meta property="article:section" content={category} />}
		{isPostPage && tags && tags.map(tag => <meta property="article:tag" content={tag} />)}
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={pageTitle} />
		<meta property="twitter:description" content={metaDescription} />
		<meta property="twitter:image" content={ogImage} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
		{favicons.map(favicon => (
			<link rel="icon"
				  href={favicon.src.startsWith('/') ? makeUrl(favicon.src) : favicon.src}
				  sizes={favicon.sizes}
				  media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
			/>
		))}
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
		<link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
		<link rel="prefetch" as="image" href="" />
		{/* 预加载关键视觉资源 */}
		<link rel="preload" href="" as="image" />
		<script>
            import { PageLifecycle } from "../scripts/page-lifecycle";
            import { $scrollProgress, $isNavMenuOpen } from "../store/app";
            // Listen to drawer state and toggle class on body
            $isNavMenuOpen.subscribe((isOpen) => {
                if (isOpen) {
                    document.body.classList.add('drawer-open');
                } else {
                    document.body.classList.remove('drawer-open');
                }
            });
            const syncTheme = () => {
                const theme = localStorage.getItem('theme') || 'auto';
                if (theme === 'dark' || (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            };
            const updateScrollProgress = () => {
                const winScroll = window.scrollY;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
                $scrollProgress.set(Math.round(scrolled));
            };
            window.addEventListener('scroll', updateScrollProgress, { passive: true });
            document.addEventListener('astro:page-load', () => {
                PageLifecycle.onPageLoad();
                updateScrollProgress();
                const bar = document.getElementById('nav-progress');
                if (bar) {
                    bar.classList.remove('loading', 'finishing');
                    bar.style.width = '0%';
                }
            });
            document.addEventListener('astro:after-swap', () => {
                syncTheme();
                updateScrollProgress();
                const isHome = window.location.pathname === '/' || /^\/page\/\d+/.test(window.location.pathname);
                if (isHome) document.body.classList.add('is-home');
                else document.body.classList.remove('is-home');
            });
            document.addEventListener('astro:before-preparation', () => {
                const bar = document.getElementById('nav-progress');
                if (bar) bar.classList.add('loading');
                if (window.artalkInstance) {
                    try { window.artalkInstance.destroy(); } catch(e) { console.warn("[Artalk] Destroy failed:", e); }
                    window.artalkInstance = null;
                }
            });
            document.addEventListener('astro:after-preparation', () => {
                const bar = document.getElementById('nav-progress');
                if (bar) {
                    bar.classList.add('finishing');
                    setTimeout(() => {
                        bar.classList.remove('loading', 'finishing');
                        bar.style.width = '0%';
                    }, 500);
                }
            });
            syncTheme();
            if (document.readyState === 'complete') {
                PageLifecycle.init();
            }
        </script>
        <style define:vars={{
            'banner-height': `${BANNER_HEIGHT}vh`,
            'banner-height-total': `${BANNER_HEIGHT + BANNER_HEIGHT_EXTEND}vh`,
            'page-width': `${PAGE_WIDTH}rem`,
            'overlap-height': `${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem`,
        }}></style>
        <style is:inline>
        #nav-progress { position: fixed; top: 0; left: 0; width: 0%; height: 2px; background: var(--primary); z-index: 10000; transition: width 0.3s ease, opacity 0.3s ease; pointer-events: none; }
        #nav-progress.loading { opacity: 1; width: 30%; }
        #nav-progress.finishing { width: 100%; opacity: 0; }
        #copy-toast { position: fixed; top: 2rem; left: 50%; transform: translateX(-50%) translateY(-100px); background: var(--card-bg); border: 1px solid var(--primary); color: var(--primary); padding: 0.8rem 1.5rem; border-radius: var(--radius-large); font-size: 0.875rem; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); z-index: 1000; transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); opacity: 0; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.2rem; pointer-events: none; }
            #copy-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
            #copy-toast .toast-title { font-weight: 900; font-size: 1rem; letter-spacing: 0.05em; }
            #copy-toast .toast-sub { font-weight: 500; font-size: 0.75rem; opacity: 0.8; }
		</style>
		<slot name="head"></slot>
		<ClientRouter />
	        </head>
	                                <body class:list={[{"is-home": isHomePage, "enable-banner": enableBanner}]} data-author={profileConfig.name} data-site={siteConfig.title}>
                                            <div id="push-wrapper" class="transition-transform duration-300 ease-in-out">
                                                <SideDrawer client:idle items={links.map(l => ({ label: l.name, href: l.url }))} activePath={currentPath} siteTitle={siteConfig.title} authorName={profileConfig.name} authorBio={profileConfig.bio} avatarSrc={profileConfig.avatar} />
                                                <div id="content-main">
                                                    <div id="copy-toast"><div class="toast-title">{i18n(I18nKey.copyToastTitle)}</div><div class="toast-sub">{i18n(I18nKey.copyToastSub)}</div></div>
                                                    <ConfigCarrier></ConfigCarrier>
                                                    <slot />
                                                    <PostHog />
                                                    <Footer />
                                                </div>
                                            </div>
	</body></html>
<style is:global>
    .aplayer .aplayer-info .aplayer-controller .aplayer-bar-wrap .aplayer-bar .aplayer-played { background: var(--primary) !important; }
    .aplayer .aplayer-info .aplayer-controller .aplayer-bar-wrap .aplayer-bar .aplayer-played .aplayer-thumb { background: var(--primary) !important; }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    body {
        overflow-x: hidden;
        background-color: var(--page-bg);
    }
    body.drawer-open {
        overflow: hidden;
    }
    #push-wrapper {
        display: flex;
        width: calc(100vw + 300px);
        transform: translateX(-300px);
        transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
        will-change: transform;
        min-height: 100vh;
    }
    #content-main {
        width: 100vw;
        flex-shrink: 0;
        position: relative;
        min-height: 100vh;
        background-color: var(--page-bg);
    }
    /* 修正移动端顶部导航在 transform 容器中的表现 */
    #push-wrapper nav.fixed {
        position: absolute !important;
        left: 300px !important;
        width: 100vw !important;
    }
    body.drawer-open #push-wrapper {
        transform: translateX(0);
    }
</style>
<style is:inline>
@media (min-width: 1024px) {
    #push-wrapper {
        transform: translateX(0) !important;
        width: 100vw;
        transition: none !important;
    }
    #content-main {
        width: calc(100vw - 300px);
        flex-shrink: 1;
    }
    #push-wrapper nav.fixed {
        display: none !important;
    }
}
</style>
