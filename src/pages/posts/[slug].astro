---
import { render } from "astro:content";

import { CopyrightCard } from "@components/post/CopyrightCard";
import RelatedNodes from "@components/post/RelatedNodes.astro";
import Comments from "../../components/post/Comments.astro";
import PostHero from "../../components/post/PostHero.astro";
import SeriesNotice from "../../components/post/SeriesNotice.astro";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import PostHog from "../../components/posthog.astro";
import { profileConfig, siteConfig } from "../../config";
import Layout from "../../layouts/Layout.astro";
import { getRelatedPosts, getSortedPosts } from "../../utils/content-utils";
import "../../styles/tokens.css";
import "../../styles/markdown.css";
import "../../styles/expressive-code.css";
import "../../styles/cepato.css";

export async function getStaticPaths() {
	const posts = await getSortedPosts(false);
	return posts.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry, posts },
	}));
}

const { entry, posts } = Astro.props;
const { Content } = await render(entry);

const relatedNodes = await getRelatedPosts(entry, 3);
const relatedPosts = relatedNodes.map((p) => ({
	title: p.data.title,
	href: `/posts/${p.slug}`,
}));

const currentIndex = posts.findIndex((p) => p.slug === entry.slug);
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : null;

const navItems = [
	{ label: "Home", href: "/" },
	{ label: "Archive", href: "/archive" },
	{ label: "Friends", href: "/links" },
	{ label: "About", href: "/about" },
];

const pageTitle = `${entry.data.title} - ${siteConfig.title}`;
const metaDescription = entry.data.description
	? entry.data.description.length > 160
		? `${entry.data.description.substring(0, 157)}...`
		: entry.data.description
	: siteConfig.subtitle;
---
<Layout title={pageTitle} description={metaDescription}>
	<div class="flex flex-col items-center gap-0 pt-14 overflow-x-hidden">

		<PostHero
			title={entry.data.title}
			slug={entry.slug}
			published={entry.data.published}
			tags={entry.data.tags}
		/>

		<article class="relative w-full max-w-[840px] bg-lt-bg paper-texture shadow-2xl px-6 md:px-16 py-10 md:py-16 overflow-hidden min-h-[400px]">
			<div class="watermark top-40 -left-10 text-[180px]" style="opacity: 0.02; color: #1A1814;">ANALYSIS</div>

			{entry.data.description && (
				<div class="relative z-10 flex mb-12 md:mb-16 bg-lt-surface border-l-[3px] border-lt-accent px-5 py-4">
					<p class="font-cn text-[15px] leading-[1.8] font-bold text-lt-ink">
						TL;DR：{entry.data.description}
					</p>
				</div>
			)}

			<div class="relative z-10 prose custom-md max-w-none prose-img:rounded-sm">
				<Content />
			</div>

			<div class="relative z-10 mt-20 pt-8 border-t border-lt-ink flex flex-col md:flex-row justify-between items-center md:items-end gap-6">
				<div class="flex items-center gap-4">
					<div class="inline-flex border-[1.5px] border-lt-ink p-[1px] bg-white leading-none">
						<span class="px-1 text-[14px] font-[900] italic text-lt-ink">R</span>
						<span class="bg-rl-red text-white px-1.5 text-[14px] font-[900] italic">P</span>
					</div>
					<div class="font-mono text-[10px] md:text-[11px] text-lt-ghost leading-tight uppercase tracking-tighter text-center md:text-left">
						Rhine Lab Pioneer Division<br/>Auth_Verified: {entry.data.published.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
					</div>
				</div>
				<span class="font-mono text-[10px] md:text-[11px] text-lt-ghost uppercase tracking-[0.6em] font-black">// END OF POST</span>
			</div>

			<div class="absolute bottom-0 left-0 right-0 h-[3px] flex">
				<div class="bg-rl-teal w-1/3"></div><div class="bg-rl-gold w-1/3"></div><div class="bg-rl-red w-1/3"></div>
			</div>
		</article>


		<div class="relative w-full max-w-[840px] bg-lt-bg paper-texture shadow-2xl px-6 md:px-16 py-8 border-t border-lt-border/10 group">
			<div class="absolute top-2 left-2 w-2 h-2 border-t border-l border-lt-ink transition-all group-hover:scale-110" />
			<div class="absolute bottom-2 right-2 w-2 h-2 border-b border-r border-lt-ink transition-all group-hover:scale-110" />
			<div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between">
				<div>
					<p class="font-display text-lg text-lt-ink uppercase tracking-tight leading-none mb-1">
						{i18n(I18nKey.subscribe)}
					</p>
					<p class="font-cn text-[13px] text-lt-muted leading-relaxed">
						{i18n(I18nKey.subscribeDesc)}
					</p>
				</div>
				<a
					href="/subscribe/"
					class="shrink-0 px-5 py-2.5 border border-lt-ink font-mono text-[11px] font-bold uppercase tracking-[0.2em] text-lt-ink hover:bg-lt-ink hover:text-lt-bg transition-colors duration-150"
				>
					Follow
				</a>
			</div>
		</div>

		<SeriesNotice tags={entry.data.tags} category={entry.data.category} />

		<CopyrightCard
			client:load
			title={entry.data.title}
			published={entry.data.published}
			tags={entry.data.tags || []}
		/>

		<RelatedNodes
			nodes={relatedPosts}
			nextPost={nextPost ? {
				title: nextPost.data.title,
				href: `/posts/${nextPost.slug}`,
				id: `PTL-${nextPost.slug.toUpperCase().slice(0, 4)}`
			} : undefined}
		/>

		<Comments />

	</div>
</Layout>
