---
import ArchiveHeader from "@components/pages/ArchiveHeader.astro";
import { LinkManifest } from "@components/pages/LinkManifest";
// SideDrawer import removed.
import StripeFooter from "@components/ui/StripeFooter.astro";
import Comments from "../components/post/Comments.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { siteConfig } from "../config";
import links from "../data/links.yml";
import Layout from "../layouts/Layout.astro";
import "../styles/cepato.css";

const navItems = [
	{ label: "Home", href: "/" },
	{ label: "Archive", href: "/archive" },
	{ label: "Friends", href: "/links" },
	{ label: "About", href: "/about" },
];

const getAvatar = (avatar: string) => {
	if (!avatar) return null;
	if (avatar.startsWith("@/assets/")) {
		return `/${avatar.replace("@/assets/", "")}`;
	}
	return avatar;
};

const linksLabel = i18n(I18nKey.links);
const pageTitle = `${linksLabel} - ${siteConfig.title}`;
const metaDescription = `${siteConfig.title} ${linksLabel}`;
---
<Layout title={pageTitle} description={metaDescription}>
	<div class="py-12 md:py-16 flex flex-col items-center gap-0 overflow-x-hidden pt-14">

		<ArchiveHeader
			title={i18n(I18nKey.links)}
			count={links.reduce((acc: any, curr: any) => acc + curr.links.length, 0)}
			variant="dark"
		/>

		{links.map((category: any) => (
			<div class="relative w-full max-w-[840px] bg-lt-bg paper-texture shadow-2xl px-6 md:px-16 py-12 border-b border-lt-border/30">
				<div class="flex items-center gap-3 mb-10">
					<span class="text-[11px] font-mono font-semibold text-lt-muted uppercase tracking-[0.2em]">{category.title}</span>
					<div class="flex-1 h-[1px] bg-lt-border"></div>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
					{category.links.map((friend: any, i: number) => (
						<a href={`/go/?url=${encodeURIComponent(friend.link)}`} target="_blank" class="group block space-y-4">
							<div class="flex items-start gap-4">
								<div class="relative w-16 h-16 bg-lt-surface border border-lt-border p-1 shrink-0 flex items-center justify-center overflow-hidden">
									<div class="absolute -top-1 -left-1 w-3 h-3 border-t border-l border-lt-ink"></div>
									<div class="absolute -bottom-1 -right-1 w-3 h-3 border-b border-r border-lt-ink"></div>
									{friend.avatar ? (
										<img src={getAvatar(friend.avatar)} class="w-full h-full object-cover bg-neutral-300" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
									) : null}
									<svg class="w-8 h-8 text-lt-ghost" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style={friend.avatar ? 'display:none' : ''}>
										<path d="M12 21a9 9 0 100-18 9 9 0 000 18z" stroke-linecap="round" stroke-linejoin="round"/>
										<path d="M12 12v6m0-6l-3-3m3 3l3-3" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
								</div>
								<div class="flex-1 min-w-0">
									<h3 class="font-display text-xl text-lt-ink uppercase tracking-tight leading-none mb-1 group-hover:text-lt-accent transition-colors">{friend.name}</h3>
									<p class="font-cn text-[11px] text-lt-muted leading-tight line-clamp-1 italic">{friend.description || i18n(I18nKey.noDescription)}</p>
								</div>
							</div>
							<div class="h-[1px] w-full bg-lt-border group-hover:bg-lt-accent transition-colors"></div>
							<div class="flex justify-between items-center text-[10px] font-mono text-lt-ghost uppercase tracking-widest">
								<span>NODE_0{(i+1).toString().padStart(2,'0')} // SYNC_OK</span>
								<span class="text-lg font-display text-lt-ink opacity-20 group-hover:opacity-100 group-hover:translate-x-1 transition-all">→</span>
							</div>
						</a>
					))}
				</div>
				<StripeFooter />
			</div>
		))}

		<LinkManifest client:load />

		<Comments />

	</div>
</Layout>
