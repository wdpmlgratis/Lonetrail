---
import Button from "../components/ui/Button";
import RhineLayout from "../layouts/RhineLayout.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
---
<RhineLayout title={`404 - ${i18n(I18nKey.notFound)}`}>
    <header class="relative w-full bg-[#1A1814] text-[#EDE6D6] paper-texture px-6 md:px-16 py-16 md:py-32 overflow-hidden">
        <div class="absolute -top-6 -right-10 font-display text-[150px] md:text-[300px] opacity-[0.03] pointer-events-none select-none">INVALID</div>
        <div class="relative z-10 max-w-4xl mx-auto flex flex-col md:flex-row md:items-end justify-between gap-12">
            <div class="space-y-6">
                <div class="flex items-center gap-2">
                    <div class="w-[3px] h-[10px] bg-[#D4621A]"></div>
                    <span class="text-[11px] tracking-[0.2em] font-bold text-[#EDE6D6]/80 uppercase">System // Error_Report</span>
                </div>
                <div class="space-y-2">
                    <h1 class="font-bold text-[100px] md:text-[160px] leading-none text-[#EDE6D6]">404</h1>
                    <h2 class="font-black text-[32px] md:text-[56px] leading-none text-[#EDE6D6] opacity-90 font-serif">{i18n(I18nKey.notFound)}</h2>
                </div>
            </div>
            <div class="text-left md:text-right space-y-2">
                <p class="text-[11px] text-[#D4621A] font-bold uppercase tracking-widest">Signal_Lost // Connectivity_Fail</p>
                <p class="text-[11px] text-[#EDE6D6]/30 uppercase leading-tight">Ref_ID: PTL-ERR-DATA-INVALID<br>Institutional Registry Access Denied</p>
            </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] flex z-20">
            <div class="bg-[#4B8D9E] w-1/3"></div><div class="bg-[#C29145] w-1/3"></div><div class="bg-[#A33332] w-1/3"></div>
        </div>
    </header>

    <main class="relative w-full flex-1 bg-[#EDE6D6] paper-texture px-6 md:px-16 py-12 md:py-24">
        <div class="max-w-4xl mx-auto space-y-16">
            <div class="space-y-6">
                <div class="flex items-center gap-3">
                    <h2 class="text-[11px] font-black text-[#6B6456] uppercase tracking-[0.3em]">01 // Fault_Summary</h2>
                    <div class="flex-1 h-[1px] bg-[#C8BFA8]"></div>
                </div>
                <p class="font-serif text-[16px] leading-[1.8] text-[#1A1814] font-medium max-w-2xl text-justify">
                    {i18n(I18nKey.notFoundDesc)}
                </p>
            </div>

            <div class="flex pt-4">
                <Button as="a" href="/" variant="unstyled" className="group flex-1 md:flex-none md:min-w-[320px] bg-[#D4621A] text-[#EDE6D6] text-[11px] font-bold uppercase tracking-[0.2em] py-5 text-center transition-all flex items-center justify-center gap-3 animate-breathing-glow">
                    <span class="text-lg leading-none">←</span>
                    {i18n(I18nKey.returnHome)} // Return_to_Root
                </Button>
            </div>

            <footer class="mt-32 pt-8 border-t border-[#C8BFA8] flex flex-col md:flex-row justify-between items-center md:items-end gap-8 opacity-60">
                <div class="flex items-center gap-4">
                    <div class="inline-flex border-[1.5px] border-[#1A1814] p-[1px] bg-white leading-none">
                        <span class="px-1 text-[14px] font-[900] italic text-[#1A1814]">R</span>
                        <span class="bg-[#A33332] text-white px-1.5 text-[14px] font-[900] italic">P</span>
                    </div>
                    <div class="text-[10px] text-[#A89F90] uppercase tracking-tighter text-center md:text-left">Rhine Lab Pioneer Division<br>Diagnostic Manifest Verified // 2026.04</div>
                </div>
                <span class="text-[10px] text-[#A89F90] uppercase tracking-[0.6em] font-black italic">// SYSTEM FAILURE RECORDED</span>
            </footer>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] flex">
            <div class="bg-[#4B8D9E] w-1/3"></div><div class="bg-[#C29145] w-1/3"></div><div class="bg-[#A33332] w-1/3"></div>
        </div>
    </main>
</RhineLayout>
