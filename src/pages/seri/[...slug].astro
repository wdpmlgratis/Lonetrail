---
import { getCollection, render } from "astro:content";
import ArchiveHeader from "@components/pages/ArchiveHeader.astro";
import SpecPanel from "@components/pages/SpecPanel";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import Layout from "../../layouts/Layout.astro";
import { getSortedPosts } from "../../utils/content-utils";
import "../../styles/cepato.css";

export async function getStaticPaths() {
	const series = await getCollection("seri");
	return series.map((seri) => ({
		params: { slug: seri.id },
		props: { seri },
	}));
}

const { seri } = Astro.props;
const { title, subtitle, description, filter } = seri.data;
const { Content } = await render(seri);

const allPosts = await getSortedPosts();
const filteredPosts = allPosts.filter((post) => {
	if (!filter) return false;
	if (filter.tag && post.data.tags?.includes(filter.tag)) return true;
	if (filter.category && post.data.category === filter.category) return true;
	return false;
});

const pageTitle = `${title} - ${subtitle || i18n(I18nKey.series)}`;

// 为 SEO 准备实体列表
const seriesEntities = filteredPosts.map((post) => ({
	title: post.data.title,
	url: new URL(`/posts/${post.slug}/`, Astro.site).toString(),
}));
---

<Layout 
    title={pageTitle} 
    description={description} 
    banner={seri.data.image}
    entities={seriesEntities}
>
	<div class="py-12 md:py-16 flex flex-col items-center gap-0 overflow-x-hidden pt-14">
		
		<ArchiveHeader
			title={title}
			count={filteredPosts.length}
			variant="dark"
		/>

		<div class="w-full max-w-[840px] mt-8 mb-12 px-6 md:px-16">
			<article class="prose custom-md max-w-none font-cn text-lt-ink/80">
				<Content />
			</article>
		</div>

		<SpecPanel client:load sortedPosts={filteredPosts} sortOrder={seri.data.sortOrder} />
	</div>
</Layout>
