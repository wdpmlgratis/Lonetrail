---
import Button from "../../components/ui/Button";
import RhineLayout from "../../layouts/RhineLayout.astro";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
---
<RhineLayout title={i18n(I18nKey.redirectConfirm)}>
    <header class="relative w-full bg-[#1A1814] text-[#EDE6D6] paper-texture px-6 md:px-16 py-12 md:py-24 overflow-hidden">
        <div class="absolute -top-6 -right-10 font-display text-[120px] md:text-[220px] opacity-[0.03] pointer-events-none select-none">SECURITY</div>
        <div class="relative z-10 max-w-4xl mx-auto space-y-12">
            <div class="flex justify-between items-start">
                <div class="space-y-1">
                    <div class="flex items-center gap-2">
                        <div class="w-[3px] h-[10px] bg-[#D4621A]"></div>
                        <span class="text-[11px] tracking-[0.2em] font-bold text-[#EDE6D6]/80 uppercase">System // Interstitial_Link</span>
                    </div>
                </div>
            </div>
            <h1 class="font-serif font-black text-[48px] md:text-[72px] leading-none text-[#EDE6D6]">{i18n(I18nKey.redirectConfirm)}</h1>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] flex z-20">
            <div class="bg-[#4B8D9E] w-1/3"></div><div class="bg-[#C29145] w-1/3"></div><div class="bg-[#A33332] w-1/3"></div>
        </div>
    </header>

    <main class="relative w-full bg-[#EDE6D6] paper-texture px-6 md:px-16 py-12 md:py-20 min-h-[50vh]">
        <div class="max-w-4xl mx-auto space-y-12">
            <div class="space-y-6">
                <div class="flex items-center gap-3">
                    <h2 class="text-[11px] font-black text-[#6B6456] uppercase tracking-[0.3em]">01 // Request_Summary</h2>
                    <div class="flex-1 h-[1px] bg-[#C8BFA8]"></div>
                </div>
                <p class="font-serif text-[16px] leading-[1.8] text-[#1A1814] font-medium max-w-2xl">
                    {i18n(I18nKey.redirectWarning)}
                </p>
            </div>
            <div class="bg-[#E4DCC8] border border-[#C8BFA8] p-6 relative">
                <span class="absolute top-0 right-2 text-[9px] text-[#A89F90] uppercase tracking-widest font-bold">Target_URI</span>
                <div id="target-url" data-invalid={i18n(I18nKey.invalidParams)} class="font-mono text-[14px] md:text-[16px] text-[#1A1814] break-all leading-relaxed font-bold">{i18n(I18nKey.loading)}</div>
            </div>
            <div class="flex flex-col md:flex-row gap-4 pt-10">
                <Button id="cancel-btn" variant="unstyled" className="flex-1 border border-[#1A1814] text-[#1A1814] text-[11px] font-bold uppercase tracking-[0.3em] py-5 text-center hover:bg-[#E4DCC8] transition-all">Cmd // Abort_Redirect</Button>
                <Button as="a" id="continue-link" href="#" variant="unstyled" className="flex-1 bg-[#1A1814] text-[#EDE6D6] text-[11px] font-bold uppercase tracking-[0.3em] py-5 text-center hover:bg-[#6B6456] transition-all flex items-center justify-center gap-2">
                    Execute // Continue_to_Target
                    <span class="text-lg leading-none">→</span>
                </Button>
            </div>
            <footer class="mt-20 pt-8 border-t border-[#C8BFA8] flex flex-col md:flex-row justify-between items-center md:items-end gap-8 opacity-60">
                <div class="flex items-center gap-4">
                    <div class="inline-flex border-[1.5px] border-[#1A1814] p-[1px] bg-white leading-none">
                        <span class="px-1 text-[14px] font-[900] italic text-[#1A1814]">R</span>
                        <span class="bg-[#A33332] text-white px-1.5 text-[14px] font-[900] italic">P</span>
                    </div>
                    <div class="text-[10px] text-[#A89F90] uppercase tracking-tighter">Rhine Lab Pioneer Division<br/>Security Protocol Verified</div>
                </div>
            </footer>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] flex">
            <div class="bg-[#4B8D9E] w-1/3"></div><div class="bg-[#C29145] w-1/3"></div><div class="bg-[#A33332] w-1/3"></div>
        </div>
    </main>

    <script>
        const initRedirect = () => {
            const targetDisplay = document.getElementById("target-url");
            if (!targetDisplay) return;
            const urlParams = new URLSearchParams(window.location.search);
            let targetUrl = urlParams.get("url");
            if (!targetUrl && urlParams.get("target")) {
                try {
                    targetUrl = atob(urlParams.get("target") || "");
                } catch { /* optional base64 fallback */ }
            }
            const continueLink = document.getElementById("continue-link") as HTMLAnchorElement;
            const cancelBtn = document.getElementById("cancel-btn");
            if (!targetUrl) {
                targetDisplay.innerText = targetDisplay.dataset.invalid || "Invalid Link";
                return;
            }
            targetDisplay.innerText = decodeURIComponent(targetUrl);
            if (continueLink) {
                continueLink.href = targetUrl;
                continueLink.target = "_blank";
                continueLink.rel = "nofollow noopener noreferrer";
            }
            if (cancelBtn) {
                cancelBtn.onclick = () => {
                    if (window.history.length > 1) window.history.back();
                    else window.location.href = "/";
                };
            }
        };

        // 支持 View Transitions
        document.addEventListener('astro:page-load', initRedirect);
        // 初始加载
        initRedirect();
    </script>
</RhineLayout>
